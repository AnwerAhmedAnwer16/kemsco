<odoo>
    <data>

        <record id="sale_order_contract_form_inherit"
                model="ir.ui.view">
            <field name="name">sale.order.form.contract.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">

                <!-- Smart Buttons -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_open_contract"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text-o"
                            invisible="not contract_id">
                        <field name="contract_id" invisible="1"/>
                        <span>العقد</span>
                    </button>
                    <button name="action_open_project_from_contract"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-sitemap"
                            invisible="not contract_id">
                        <span>المشروع</span>
                    </button>
                </xpath>

                <!-- Field in form -->
                <xpath expr="//field[@name='payment_term_id']"
                       position="after">
                    <field name="contract_id"
                           invisible="not contract_id"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>