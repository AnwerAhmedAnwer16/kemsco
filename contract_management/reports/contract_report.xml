<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_report_contract" model="ir.actions.report">
            <field name="name">طباعة العقد</field>
            <field name="model">contract.management</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">contract_management.report_contract_template</field>
            <field name="report_file">contract_management.report_contract_template</field>
            <field name="print_report_name">'العقد - %s' % (object.name)</field>
            <field name="binding_model_id" ref="model_contract_management"/>
            <field name="binding_type">report</field>
        </record>

        <template id="report_contract_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page" dir="rtl" style="direction:rtl; text-align:right; font-size:10pt; color:#000; line-height:1.7;">

                            <style>
                                @font-face {
                                    font-family: 'Cairo';
                                    src: url('/contract_management/static/fonts/Cairo-Regular.ttf') format('truetype');
                                    font-weight: normal;
                                    font-style: normal;
                                }
                                .cpage {
                                    font-family: 'Cairo', 'DejaVu Sans', sans-serif;
                                }
                            </style>

                            <div class="cpage">

                                <!-- العنوان -->
                                <p dir="rtl" style="text-align:center; font-size:18pt; font-weight:bold; margin:0 0 2px 0;">عقد صيانة</p>
                                <p dir="rtl" style="text-align:center; font-size:12pt; font-weight:bold; margin:0 0 6px 0;">أنظمة مكافحة وإنذار الحريق</p>

                                <!-- التاريخ والرقم التسلسلي -->
                                <table dir="rtl" style="width:100%; direction:rtl; border-collapse:collapse; margin-bottom:8px;">
                                    <tr>
                                        <td dir="rtl" style="text-align:right;">
                                            التاريخ : <b><t t-esc="str(o.date_start)"/></b>
                                        </td>
                                        <td dir="rtl" style="text-align:right;">
                                            الرقم التسلسلي : <b><t t-esc="o.name"/></b>
                                        </td>
                                    </tr>
                                </table>

                                <!-- الأطراف -->
                                <table dir="rtl" style="width:100%; direction:rtl; border-collapse:collapse; margin-bottom:6px;">
                                    <tr>
                                        <td dir="rtl" style="text-align:right; padding:2px 0;">الشركة الكويتية لأنظمة الكتروميكانيك للمقاولات العامة للمباني ذ.م.م</td>
                                        <td dir="rtl" style="text-align:left; font-weight:bold; width:70px; padding:2px 0;">طرف اول</td>
                                    </tr>
                                    <tr>
                                        <td dir="rtl" style="text-align:right; padding:2px 0;"><b><t t-esc="o.partner_id.name"/></b></td>
                                        <td dir="rtl" style="text-align:left; font-weight:bold; width:70px; padding:2px 0;">طرف ثاني</td>
                                    </tr>
                                </table>

                                <!-- تمهيد -->
                                <p dir="rtl" style="text-align:center; font-weight:bold; font-size:12pt; margin:8px 0 4px 0;">تمهيد</p>
                                <p dir="rtl" style="text-align:right; margin:0 0 3px 0;">
                                    حيث ان الطرف الاول شركة متخصصة في صيانة انظمة مكافحة وإنذار الحريق وهي معتمدة لدى الادارة العامة للإطفاء لمزاولة الاعمال الخدماتية موضوع هذا العقد ولما كان الطرف الثاني يرغب في اسناد مهمة القيام بأعمال الصيانة للطرف الاول وفقا للشروط التالية :-
                                </p>
                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0;">التمهيد السابق جزء لا يتجزأ من هذا العقد</p>

                                <!-- البنود -->
                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    1. يلتزم الطرف الأول بعمل الصيانة اللازمة لمعدات نظام مكافحة وإنذار الحريق في مبنى الطرف الثاني <b><t t-esc="o.partner_id.street or ''"/></b>
                                </p>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    2. يقوم الطرف الأول بعمل زيارات دورية بواقع زيارة كل <b><t t-esc="o.visits_frequency or 'شهر'"/></b>
                                </p>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    3. في حال وجود اي اعطال في انظمة مكافحة وانذار الحريق يتطلب توريد قطع غيار او مواد لإصلاحها يقدم الطرف الاول عرض سعر مع تحديد الفترة الزمنية الازمة للموافقة.
                                </p>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    4. في حالة حدوث عطل في معدات مكافحة الحريق الغير مكشوفة على سبيل المثال لا الحصر المدفونة تحت الارض او البلاط او الاسفلت او المركبة فوق السقف الصناعي او خلف اي نوع من انواع الديكورات او الاجهزة او المعدات فعلى الطرف الثاني ازالة هذه المعوقات حتى يتمكن الطرف الأول من اجراء الفحص ومن ثم اعمال الصيانة
                                </p>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    5. في حال قيام الطرف الثاني بأجراء اي اعمال مدنيه والإصلاحات داخل المبنى يترتب عليها تعطيل ووقف اي من انظمة ومعدات مكافحة وانذار الحريق فعليه اخطار الطرف الاول بذلك كتابيا
                                </p>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    6. يقوم الطرف الاول بحضور الفحص الدوري للإدارة العامة للإطفاء على ان يتم اخطاره خطيا او اتصاليا من قبل الطرف الثانى قبل موعد الكشف بأسبوع على الاقل
                                </p>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    7. في حالة حدوث اي خلل طارئ في المعدات خلال فترات الصيانة الدورية فترة العقد فعلى الطرف الثانى أخطار الطرف الاول حتى يتسنى له فحص هذا الخلل واي نتائج تترتب عن عدم الاخطار تكون مسئولية الطرف الثانى .
                                </p>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    8. يتحمل الطرف الثانى كافة الرسوم المستحقة لدى الادارة العامة للإطفاء.
                                </p>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    9. هذا العقد لا يعتبر بوليصة تامين ولا يغني عنها ويتحمل الطرف الثاني مسئولية التامين على المبنى .
                                </p>

                                <div dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    10. قيمة هذا العقد وشروط السداد:
                                    <table dir="rtl" style="width:85%; margin:6px 20px 4px 0; border-collapse:collapse; border:1pt solid #ddd;">
                                        <tr>
                                            <td dir="rtl" style="text-align:right; padding:4px 8px; font-weight:bold; background-color:#f5f5f5; border-left:1pt solid #ddd; width:30%;">القيمة الإجمالية</td>
                                            <td dir="rtl" style="text-align:right; padding:4px 8px; font-weight:bold;"><t t-esc="'{:,.3f}'.format(o.contract_value)"/> <t t-esc="o.currency_id.name or ''"/></td>
                                        </tr>
                                        <tr>
                                            <td dir="rtl" style="text-align:right; padding:4px 8px; font-weight:bold; background-color:#f5f5f5; border-left:1pt solid #ddd; border-top:1pt solid #ddd;">شروط السداد</td>
                                            <td dir="rtl" style="text-align:right; padding:4px 8px; font-weight:bold; border-top:1pt solid #ddd;"><t t-esc="o.payment_terms or '-'"/></td>
                                        </tr>
                                    </table>
                                </div>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    <t t-set="delta" t-value="(o.date_end.year - o.date_start.year) * 12 + o.date_end.month - o.date_start.month"/>
                                    11. مدة هذا العقد
                                    <b><t t-if="delta >= 12"><t t-esc="delta // 12"/> سنة</t><t t-if="delta % 12 > 0 and delta >= 12"> و <t t-esc="delta % 12"/> شهر</t><t t-if="delta &lt; 12"><t t-esc="delta"/> شهر</t></b>
                                    تبدأ في <b><t t-esc="str(o.date_start)"/></b> وينتهي في <b><t t-esc="str(o.date_end)"/></b>
                                </p>

                                <p dir="rtl" style="text-align:right; margin:0 0 6px 0; padding-right:14px;">
                                    12. حرر هذا العقد من نسختين بيد كل طرف نسخة للعمل بموجبها عند اللزوم ويعتبر هذا العقد مبرما داخل دولة الكويت ويجب ان يفسر وينفذ من جميع الوجوه حسب القانون الكويتي واي خلاف او نزاع مهما كان نوعه قد ينشأ عن تنفيذ هذا العقد او بسببه فان المحاكم الكويتية فقط هي المختصة بالفصل بهذا النزاع.
                                </p>

                                <!-- التوقيعات -->
                                <table dir="rtl" style="width:100%; direction:rtl; margin-top:30px; border-collapse:collapse;">
                                    <tr>
                                        <td dir="rtl" style="text-align:center; width:50%; vertical-align:top; padding:0 16px;">
                                            <p style="font-weight:bold; margin:0 0 4px 0;">الطرف الأول</p>
                                            <p style="margin:0 0 4px 0; font-size:9pt;">الشركة الكويتية لأنظمة الكتروميكانيك</p>
                                            <img src="/contract_management/static/WhatsApp Image 2026-05-06 at 1.32.30 PM.jpeg" style="max-height:80px; max-width:180px; display:block; margin: 0 auto 4px auto;"/>
                                            <!-- <hr style="width:60%; border:none; border-top:1pt solid #000;"/> -->
                                        </td>
                                        <td dir="rtl" style="text-align:center; width:50%; vertical-align:top; padding:0 16px;">
                                            <p style="font-weight:bold; margin:0 0 4px 0;">الطرف الثاني</p>
                                            <p style="margin:0 0 8px 0; font-size:9pt;"><t t-esc="o.partner_id.name"/></p>
                                            <t t-if="o.signature">
                                                <img t-att-src="image_data_uri(o.signature)" style="max-height:50px; max-width:140px;"/>
                                            </t>
                                            <t t-else="">
                                                <div style="height:32px;"/>
                                            </t>
                                            <!-- <hr style="width:60%; border:none; border-top:1pt solid #000;"/> -->
                                        </td>
                                    </tr>
                                </table>

                            </div><!-- /cpage -->
                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>