<odoo>
    <data>

        <!-- تذكير مواعيد الزيارات الميدانية -->
        <record id="ir_cron_visit_reminder" model="ir.cron">
            <field name="name">تذكير مواعيد الزيارات الميدانية</field>
            <field name="model_id"
                   ref="project.model_project_task"/>
            <field name="state">code</field>
            <field name="code">model._cron_notify_visit_assignees()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <!-- تذكير مواعيد تحصيل الفواتير -->
        <record id="ir_cron_invoice_reminder" model="ir.cron">
            <field name="name">تذكير مواعيد تحصيل الفواتير</field>
            <field name="model_id"
                   ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_notify_invoice_due()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>