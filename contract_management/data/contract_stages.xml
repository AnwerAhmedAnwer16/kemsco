<odoo>
    <data noupdate="1">

        <record id="stage_draft" model="contract.stage">
            <field name="name">مسودة</field>
            <field name="sequence">1</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_review" model="contract.stage">
            <field name="name">قيد المراجعة</field>
            <field name="sequence">2</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_approved" model="contract.stage">
            <field name="name">معتمد</field>
            <field name="sequence">3</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_active" model="contract.stage">
            <field name="name">نشط</field>
            <field name="sequence">4</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_done" model="contract.stage">
            <field name="name">منتهي</field>
            <field name="sequence">5</field>
            <field name="fold" eval="True"/>
            <field name="is_done" eval="True"/>
        </record>

        <record id="stage_cancelled" model="contract.stage">
            <field name="name">ملغي</field>
            <field name="sequence">6</field>
            <field name="fold" eval="True"/>
            <field name="is_cancelled" eval="True"/>
        </record>

    </data>
</odoo>